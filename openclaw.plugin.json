{
  "id": "libravdb-memory",
  "name": "LibraVDB Memory",
  "description": "Persistent vector memory with three-tier hybrid scoring",
  "version": "1.4.59",
  "kind": [
    "memory",
    "context-engine"
  ],
  "contracts": {
    "memory": true,
    "contextEngine": true
  },
  "activation": {
    "onCommands": [
      "memory"
    ]
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "dbPath": {
        "type": "string"
      },
      "sidecarPath": {
        "type": "string"
      },
      "userId": {
        "type": "string",
        "description": "Stable identity for cross-session durable memory. When set, sessions share memories under user:{userId}."
      },
      "identityPath": {
        "type": "string",
        "description": "Custom path for the auto-derived identity JSON file."
      },
      "crossSessionRecall": {
        "type": "boolean",
        "default": true,
        "description": "When false, only session-scoped memories are retrieved; durable user recall is skipped."
      },
      "useSessionRecallProjection": {
        "type": "boolean"
      },
      "grpcEndpoint": {
        "type": "string",
        "description": "Optional gRPC kernel endpoint for hosts using the daemon kernel transport."
      },
      "authoredHardBudgetFraction": {
        "type": "number",
        "minimum": 0,
        "maximum": 1
      },
      "authoredSoftBudgetFraction": {
        "type": "number",
        "minimum": 0,
        "maximum": 1
      },
      "elevatedGuidanceBudgetFraction": {
        "type": "number",
        "minimum": 0,
        "maximum": 1
      },
      "useSessionSummarySearchExperiment": {
        "type": "boolean"
      },
      "embeddingRuntimePath": {
        "type": "string"
      },
      "onnxDevice": {
        "type": "string",
        "enum": [
          "auto",
          "cpu",
          "cuda",
          "coreml",
          "directml",
          "openvino"
        ],
        "default": "cpu",
        "description": "Optional ONNX execution provider override passed to libravdbd. Use cpu to bypass CoreML/MPS on Intel Macs."
      },
      "embeddingBackend": {
        "type": "string",
        "enum": [
          "bundled",
          "onnx-local",
          "custom-local"
        ]
      },
      "embeddingProfile": {
        "type": "string",
        "default": "nomic-embed-text-v1.5"
      },
      "fallbackProfile": {
        "type": "string",
        "default": "bge-small-en-v1.5"
      },
      "embeddingModelPath": {
        "type": "string"
      },
      "embeddingTokenizerPath": {
        "type": "string"
      },
      "embeddingDimensions": {
        "type": "number"
      },
      "embeddingNormalize": {
        "type": "boolean"
      },
      "summarizerBackend": {
        "type": "string",
        "enum": [
          "bundled",
          "onnx-local",
          "ollama-local",
          "custom-local"
        ]
      },
      "summarizerProfile": {
        "type": "string"
      },
      "summarizerRuntimePath": {
        "type": "string"
      },
      "summarizerModelPath": {
        "type": "string"
      },
      "summarizerTokenizerPath": {
        "type": "string"
      },
      "summarizerModel": {
        "type": "string"
      },
      "summarizerEndpoint": {
        "type": "string"
      },
      "sessionTTL": {
        "type": "number"
      },
      "topK": {
        "type": "number"
      },
      "alpha": {
        "type": "number"
      },
      "beta": {
        "type": "number"
      },
      "gamma": {
        "type": "number"
      },
      "ingestionGateThreshold": {
        "type": "number",
        "default": 0.35
      },
      "markdownIngestionEnabled": {
        "type": "boolean",
        "default": false
      },
      "markdownIngestionRoots": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "markdownIngestionObsidianEnabled": {
        "type": "boolean",
        "default": false
      },
      "markdownIngestionObsidianRoots": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "markdownIngestionObsidianInclude": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "markdownIngestionObsidianExclude": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "markdownIngestionObsidianDebounceMs": {
        "type": "number",
        "default": 150
      },
      "markdownIngestionInclude": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "markdownIngestionExclude": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "markdownIngestionDebounceMs": {
        "type": "number",
        "default": 150
      },
      "dreamPromotionEnabled": {
        "type": "boolean",
        "default": false
      },
      "dreamPromotionDiaryPath": {
        "type": "string"
      },
      "dreamPromotionUserId": {
        "type": "string"
      },
      "dreamPromotionDebounceMs": {
        "type": "number",
        "default": 150
      },
      "lifecycleJournalMaxEntries": {
        "type": "number",
        "default": 500
      },
      "compactionQualityWeight": {
        "type": "number",
        "default": 0.5,
        "description": "Controls how much summary confidence affects retrieval score. 0 ignores summary quality and 1 fully suppresses zero-confidence summaries."
      },
      "recencyLambdaSession": {
        "type": "number"
      },
      "recencyLambdaUser": {
        "type": "number"
      },
      "recencyLambdaGlobal": {
        "type": "number"
      },
      "tokenBudgetFraction": {
        "type": "number"
      },
      "compactThreshold": {
        "type": "number"
      },
      "compactionThresholdFraction": {
        "type": "number",
        "default": 0.8,
        "description": "Dynamic predictive compaction trigger ratio against the active token budget. Used when compactThreshold is not explicitly set."
      },
      "compactSessionTokenBudget": {
        "type": "number",
        "default": 2000,
        "description": "Auto-trigger compaction when the session accumulates this many tokens since the last compaction. Set to 0 to disable auto-compaction."
      },
      "ollamaUrl": {
        "type": "string"
      },
      "compactModel": {
        "type": "string"
      },
      "rpcTimeoutMs": {
        "type": "number",
        "default": 30000
      },
      "maxRetries": {
        "type": "number"
      },
      "logLevel": {
        "type": "string"
      }
    }
  }
}
